# ============================================
# AgentPit - Environment Variables
# Copy to .env and fill in your values
# ============================================

# Hyperliquid
HL_WS_URL=wss://api.hyperliquid-testnet.xyz/ws
HL_API_URL=https://api.hyperliquid-testnet.xyz
HL_PRIVATE_KEY=your_private_key_here
HL_TESTNET=true

# DeepSeek (primary LLM)
DEEPSEEK_API_KEY=your_deepseek_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Redis (for job queues - Phase 2)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info
